# Beatmap statuses that contribute to player PP (and update accuracy/rank/etc).
# All scores can be submitted on any beatmap, but ONLY scores on beatmaps with
# these statuses will update player stats (PP, accuracy, ranked score, etc).
# Scores on other beatmaps only add to totalScore.
#
# Available BeatmapStatus values (API v2):
#   1 = Ranked         - Contributes to PP
#   2 = Approved       - Contributes to PP
#   3 = Qualified      - Contributes to PP (by default, configurable)
#   4 = Loved          - Does not contribute to PP by default
#   0 = Pending        - Does not contribute to PP
#   -1 = WIP          - Does not contribute to PP
#   -2 = Graveyard     - Does not contribute to PP
#
# Examples:
#   BEATMAP_PP_CONTRIBUTING_STATUSES=1         # Only Ranked
#   BEATMAP_PP_CONTRIBUTING_STATUSES=1,2       # Ranked + Approved
#   BEATMAP_PP_CONTRIBUTING_STATUSES=1,2,3     # Ranked + Approved + Qualified
#   BEATMAP_PP_CONTRIBUTING_STATUSES=1,2,3,4   # Ranked + Approved + Qualified + Loved
#
BEATMAP_PP_CONTRIBUTING_STATUSES=1,2,3
